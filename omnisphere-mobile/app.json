{
  "expo": {
    "name": "Omnisphere R18",
    "slug": "omnisphere-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.omnisphere.r18"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      },
      "package": "app.omnisphere.r18"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "omnisphere",
    "plugins": [
      "expo-router"
    ]
  }
}
